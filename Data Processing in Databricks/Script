%sql
-- Previewing the Dataset
select * 
from brightlearn.bright.coffeeshopsales;

-- Previewing column data types|Checking for nulls
describe table brightlearn.bright.coffeeshopsales;

--Checking Duplicates
select count(*) as total_row,
       count(distinct transaction_id) as distinct_ids
       from brightlearn.bright.coffeeshopsales;

--- Unique Store locations
select distinct store_location
from brightlearn.bright.coffeeshopsales;

--Previewing Products
select distinct product_category
from brightlearn.bright.coffeeshopsales;

--Checking dates
select min(transaction_date) as min_day,
       max(transaction_date) as max_day
from brightlearn.bright.coffeeshopsales;
      
--- Replacing the table

select 
  transaction_id,
  cast(transaction_date as date) as transaction_date,
  date_format(transaction_time, 'HH:mm:ss') as time,  ---cleaned transaction time
  case 
      when hour(transaction_time) between 6 and 12 then 'Morning'
      when hour(transaction_time) between 12 and 18 then 'Afternoon'
      else 'Evening'
  end as period,
  transaction_qty,
  store_id,
  store_location,
  product_id,
  product_category,
  product_type,
  product_detail,
  cast(replace(unit_price, ',', '.') as decimal(10,2)) as unit_price,     ---fixes the unit price
  cast(replace(unit_price, ',', '.') as decimal(10,2)) * transaction_qty as revenue,  ---revenue calculation
  case 
      when cast(replace(unit_price, ',', '.') as decimal(10,2)) * transaction_qty <= 50 then 'lower_rev'
      when cast(replace(unit_price, ',', '.') as decimal(10,2)) * transaction_qty between 51 and 200 then 'low_rev'
      when cast(replace(unit_price, ',', '.') as decimal(10,2)) * transaction_qty between 201 and 300 then 'med_rev'
      else 'high rev'
  end as rev_bucket,
  dayname(transaction_date) as week_days,
  monthname(transaction_date) as month_name,
  dayofmonth(transaction_date) as day_number,
  case 
      when dayname(transaction_date)= 'Sat' and dayname(transaction_date) = 'Sun' then 'Weekend'
      else 'Weekday'
  end as day_type


from brightlearn.bright.coffeeshopsales;








